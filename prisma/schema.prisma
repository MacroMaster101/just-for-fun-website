datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model YouTubeCache {
  key       String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}
