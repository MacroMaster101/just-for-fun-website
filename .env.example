# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL — Supabase / Neon)
# Use the Transaction pooler URL (port 6543) on Vercel (IPv4).
# The direct URL is IPv6-only on Supabase's free tier.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres"

# Direct (non-pooled) URL — used by Prisma for DDL operations
# (`prisma db push`, `prisma migrate`). Session pooler port 5432.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres"

# ─────────────────────────────────────────────────────────────
# Supabase Auth & Storage
# ─────────────────────────────────────────────────────────────
# Public — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL="https://YOURPROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only — bypasses Row Level Security.
# Project Settings → API → service_role key. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─────────────────────────────────────────────────────────────
# YouTube Data API v3
# ─────────────────────────────────────────────────────────────
YOUTUBE_API_KEY="your-youtube-data-api-key"
YOUTUBE_CHANNEL_ID="UCcCp0B0bypJE4EJjwq8u2lQ"
YOUTUBE_CHANNEL_HANDLE="@JustForFun-BoYs"

# Shared secret for Vercel Cron / cron-job.org → /api/youtube/refresh
# Generate one with: openssl rand -hex 32
CRON_SECRET="your-32-byte-hex-secret"

# ─────────────────────────────────────────────────────────────
# Contact Form SMTP Forwarder (Gmail / Nodemailer)
# Use a Gmail App Password (16 chars), not your account password.
# ─────────────────────────────────────────────────────────────
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-gmail-app-password"

# ─────────────────────────────────────────────────────────────
# Primary Root Administrator Email (self-seeds on first login)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL="your-admin-email@gmail.com"

# ─────────────────────────────────────────────────────────────
# RAWG Video Games Database API (free key at rawg.io/apidocs)
# ─────────────────────────────────────────────────────────────
RAWG_API_KEY="your-rawg-api-key"

# ─────────────────────────────────────────────────────────────
# Discord Webhook — Challenge Slot auto-poster
# Server-only. Create one in Discord:
#   Channel ⚙️ → Integrations → Webhooks → New Webhook → Copy URL
# ─────────────────────────────────────────────────────────────
DISCORD_CHALLENGE_WEBHOOK_URL="https://discord.com/api/webhooks/XXXX/YYYY"
